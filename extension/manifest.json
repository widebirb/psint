{
  "manifest_version": 3,
  "name": "PSINT Job Tracker",
  "version": "1.0.0",
  "description": "Manually log job applications to your PSINT Job Tracker from anywhere.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "http://localhost:5144/*"
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "PSINT Job Tracker",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}